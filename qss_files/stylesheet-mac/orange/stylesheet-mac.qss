/*
   グラデーションの設定
   下の例は左上(0,0)から右下(1,1)方向のグラデーション
*/
/* エンジョイ・シンプル・イングリッシュ */
/*
#toolButton_enjoy {
	background-color: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 1, stop: 0 whitesmoke, stop: 1 deeppink);
}
*/

/*
   まいにち中国語, レベルアップ中国語, まいにちフランス語
   まいにちイタリア語, まいにちハングル講座, レベルアップハングル講座
   まいにちドイツ語, まいにちスペイン語, まいにちロシア語
*/
/*
#toolButton_chinese, toolButton_levelup_chinese, #toolButton_french,
#toolButton_italian, #toolButton_hangeul, #toolButton_levelup_hangeul,
#toolButton_german, #toolButton_spanish, #toolButton_russian {
	background-color: darkslategray;
}
*/

/* 既存ファイルのスキップ */
#button_skip {
   background-color: darkslategray;
}

/* 既存ファイルのスキップにマウスが乗った時 */
#button_skip:hover {
   background-color: slategray;
}

QCheckBox::indicator:unchecked {
	background-color: white;   /* ← 白抜きに戻す */
	border: 1px solid #444;    /* 枠線は黒系で維持 */
}

#checkBox_next_week2 {
	background-color: black;
	color: white;
}

QLineEdit {
    border: 1px solid rgba(0,0,0,0.2);
    border-radius: 4px;
    padding: 2px;
}
QLineEdit:focus {
    border: 1.5px solid #007AFF;
}

/* 拡張子ラベル */
#label_ext {
   background-color: black;
   color: white;
}

QComboBox {
   background-color: white;   /* ← 選択後の表示部分の背景 */
   color: black;              /* ← テキスト色 */
}

/* 拡張子選択ポップアップメニュー */
#popup_ext {
   background-color: darkslategray;
   color: black;
}

#checkBox_thumbnail {
   background-color: black;
   color: white;
}

/*
#popup_ext QListView {
   background-color: darkslategray;
}

#popup_ext QListView:hover {
   color: black;
}
*/

/* 拡張子選択ポップアップメニューにマウスが乗った時 */
#popup_ext:hover {
   background-color: slategray;
}

/* ダウンロードボタン */
#downloadButton {
	background-color: darkslategray;
	color: white;
	border-top: 1px solid white;
	border-left: 1px solid white;
	border-right: 2px solid dimgray;
	border-bottom: 2px solid dimgray;
	border-radius: 10px;
	min-width: 12ex;
	min-height: 3ex;
}

/* ダウンロードボタンにマウスが乗った時 */
#downloadButton:hover {
   background-color: slategray;
}

/* ダウンロードボタンが押された時 */
#downloadButton:pressed {
	border-top: 2px solid dimgray;
	border-left: 2px solid dimgray;
	border-right: 1px solid white;
	border-bottom: 1px solid white;
}

/*
   メッセージウィンドウ
   MessageWindowはCaptureStreamで定義しているクラス名
*/
MessageWindow {
	background-color: black;
}

/*
   メッセージウィンドウにあるテキスト表示エリア
*/
MessageWindow QPlainTextEdit {
	background-color: black;
	color: white;
}

/*
   メッセージウィンドウにあるプッシュボタン
*/
MessageWindow QPushButton {
	background-color: darkslategray;
	color: white;
}

QMenuBar {
	background-color: gainsboro;
}

QMenuBar::item {
	background: transparent;
}

QMenuBar::item:selected {
	background: #a8a8a8;
}

QMenuBar::item:pressed {
	background: #888888;
}

QStatusBar {
	background-color: black;
}

MessageWindow QPlainTextEdit {
    font-family: "Menlo", "Consolas", "DejaVu Sans Mono", "Courier New", monospace;
}

QPlainTextEdit#messageTextEdit {
    font-family: "Menlo", "Consolas", "DejaVu Sans Mono", "Courier New", monospace;
}

/* メニューバー（画面上部またはウィンドウ上部のバー） */
QMenuBar {
    background-color: gainsboro;
    color: #000000;              /* 16進数で真っ黒を指定 */
    font-weight: bold;           /* 太字にして視認性を上げる */
    font-family: "Menlo", "Consolas", "DejaVu Sans Mono", "Courier New", monospace; 
}

QMenuBar::item {
    background-color: transparent;
    color: #000000;
    font-family: "Menlo", "Consolas", "DejaVu Sans Mono", "Courier New", monospace; 
}

/* メニューの項目が選択されている状態 */
QMenuBar::item:selected {
    background-color: #a8a8a8;
    color: #000000;              /* 選択時も黒を維持 */
    font-family: "Menlo", "Consolas", "DejaVu Sans Mono", "Courier New", monospace; 
}

/* ドロップダウンメニュー（クリックして出てくるリスト部分） */
QMenu {
    background-color: #FFFFFF;   /* 背景を純白に */
    color: #000000;              /* 文字を真っ黒に */
    border: 1px solid #999;
    font-weight: bold;           /* リスト内も太字にする */
}

/* ドロップダウンリスト内の各項目 */
QMenu::item {
    background-color: transparent;
    color: #000000;              /* ここでも明示的に黒を指定 */
    padding: 4px 20px;           /* 少し余白を作ると読みやすくなります */
}

/* リスト内の項目を選択した時 */
QMenu::item:selected {
    background-color: #007AFF;   /* 選択時は青背景 */
    color: #FFFFFF;              /* 青背景の時は白文字が見やすいです */
}

/* カスタマイズダイアログ全体の設定 */
CustomizeDialog {
    background-color: #FFFFFF;   /* 背景を純白に */
    color: #000000;              /* 文字を真っ黒に */
    font-weight: bold;           /* リスト内も太字にする */
    font-family: "Menlo", "Consolas", "DejaVu Sans Mono", "Courier New", monospace;
}

/* ダイアログ内のグループボックスの見た目 */
CustomizeDialog QGroupBox {
    background-color: #FFFFFF;   /* 背景を純白に */
    color: #000000;              /* 文字を真っ黒に */
    font-weight: bold;           /* リスト内も太字にする */
    font-family: "Menlo", "Consolas", "DejaVu Sans Mono", "Courier New", monospace;   
}

/* ダイアログ内のラジオボタン */
CustomizeDialog QRadioButton {
    background-color: #FFFFFF;   /* 背景を純白に */
    color: #000000;              /* 文字を真っ黒に */
    font-weight: bold;           /* リスト内も太字にする */
    font-family: "Menlo", "Consolas", "DejaVu Sans Mono", "Courier New", monospace;   
}

/* CustomizeDialog 内のQLabel の見た目 */
CustomizeDialog QLabel {
    background-color: #FFFFFF;   /* 背景を純白に */
    color: #000000;              /* 文字を真っ黒に */
    font-weight: bold;           /* リスト内も太字にする */
    font-family: "Menlo", "Consolas", "DejaVu Sans Mono", "Courier New", monospace;
}
/* CustomizeDialog 内のQCheckBox の見た目 */
CustomizeDialog QCheckBox {
    background-color: #FFFFFF;   /* 背景を純白に */
    color: #000000;              /* 文字を真っ黒に */
    font-weight: bold;           /* リスト内も太字にする */
    font-family: "Menlo", "Consolas", "DejaVu Sans Mono", "Courier New", monospace;
}
/* CustomizeDialog 内のQCheckBox の見た目 */
CustomizeDialog QLineEdit {
    background-color: #FFFFFF;   /* 背景を純白に */
    color: #000000;              /* 文字を真っ黒に */
    font-weight: bold;           /* リスト内も太字にする */
    font-family: "Menlo", "Consolas", "DejaVu Sans Mono", "Courier New", monospace;
}
