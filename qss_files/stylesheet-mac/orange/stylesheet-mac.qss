/*
   ウィジェットクラス（すべての部品の親クラス）
   Qxxxxxxのように大文字のQで始まるのはQtのクラス名
*/
QWidget {
	font-family: "Times New Roman", serif;
	font-size: 12pt;
	font-weight: normal;
	font-style: normal;

}

/*
   メインウィンドウ
   MainWindowはCaptureStreamで定義しているクラス名
*/
MainWindow {
	background-color: black;
}

/*
   ツールボタンクラス
   色は#FFFFFFのような16進表記かwhiteのようなWebカラーネームで指定
*/
QToolButton {
	background-color: orange;
	color: black;
}

#checkBox_next_week2 {
	background-color: black;
	color: white;
}

/* ツールボタンにマウスが乗った時 */
QToolButton:hover {
   background-color: yellow;
}

/*
   個別のボタンを名前で指定して設定することも可能
   複数のボタンに同時に設定する場合はカンマ区切り
   #xxxxxxのように#で始まるのが各アイテムの名前
*/
